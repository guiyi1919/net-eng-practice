    <txttips>
        <txttip left="71" top="612" right="166" bottom="644" content="vlan 10&#x0D;&#x0A;192.168.10.X" fontname="Consolas" fontstyle="0" editsize="100" txtcolor="-16777216" txtbkcolor="-7278960" charset="1" />
        <txttip left="467" top="611" right="562" bottom="643" content="vlan 20&#x0D;&#x0A;192.168.20.X" fontname="Consolas" fontstyle="0" editsize="100" txtcolor="-16777216" txtbkcolor="-7278960" charset="1" />
        <txttip left="554" top="284" right="1147" bottom="394" content="两个核心vrrp配置思路 &#x0D;&#x0A;第一步：配上真实ip（vlanif），左核心10.253，右核心10.252 &#x0D;&#x0A;第二步：配上虚拟ip（vrrp vrid 10 virtual-ip 192.168.10.254 不用敲掩码）&#x0D;&#x0A;做vrrp的多台设备中需要vrid相同才能在一个组，左核心10.254，右核心10.254 &#x0D;&#x0A;第三步:配优先级（vrrp vrid 10 priority 110【数字越大优先级越高，默认是100】）&#x0D;&#x0A;左核心优先级高,右优先级保持默认，然后查看左边交换机（dis vrrp brief）&#x0D;&#x0A;是否成功设置为主设备（Master）" fontname="Consolas" fontstyle="0" editsize="100" txtcolor="-16777216" txtbkcolor="-7278960" charset="1" />
        <txttip left="89" top="215" right="138" bottom="232" content="core-1" fontname="Consolas" fontstyle="0" editsize="100" txtcolor="-16777216" txtbkcolor="-7278960" charset="1" />
        <txttip left="490" top="205" right="539" bottom="222" content="core-2" fontname="Consolas" fontstyle="0" editsize="100" txtcolor="-16777216" txtbkcolor="-7278960" charset="1" />
        <txttip left="64" top="107" right="204" bottom="139" content="vlanif ip：10.253&#x0D;&#x0A;vrrp ip：10.254" fontname="Consolas" fontstyle="0" editsize="100" txtcolor="-16777216" txtbkcolor="-7278960" charset="1" />
        <txttip left="440" top="104" right="580" bottom="136" content="vlanif ip：10.252&#x0D;&#x0A;vrrp ip：10.254" fontname="Consolas" fontstyle="0" editsize="100" txtcolor="-16777216" txtbkcolor="-7278960" charset="1" />
    </txttips>
</topo>

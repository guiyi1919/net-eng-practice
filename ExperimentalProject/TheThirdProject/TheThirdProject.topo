        <txttip left="796" top="167" right="860" bottom="184" content="64.1.1.1" fontname="Consolas" fontstyle="0" editsize="100" txtcolor="-16777216" txtbkcolor="-7278960" charset="1" />
        <txttip left="568" top="154" right="632" bottom="171" content="出口设备" fontname="Consolas" fontstyle="0" editsize="100" txtcolor="-16777216" txtbkcolor="-7278960" charset="1" />
        <txttip left="202" top="445" right="993" bottom="568" content="在出口设备需要做些什么？&#x0D;&#x0A;用acl做筛选哪些数据包需要做nat&#x0D;&#x0A;（acl 【编号、名字】————rule permit source 【需要出口的ip网段】【反掩码】）&#x0D;&#x0A;然后进入到连接外网的接口（interface g0/0/2）&#x0D;&#x0A;配置（nat out 2000）从这个口发出的数据包，如果是acl 2000挑选的，那就需要做nat。&#x0D;&#x0A;nat之后ip会变成接口g0/0/2的ip地址" fontname="Consolas" fontstyle="0" editsize="130" txtcolor="-16777216" txtbkcolor="-7278960" charset="1" />
        <txttip left="566" top="680" right="630" bottom="697" content="ospf实验" fontname="Consolas" fontstyle="0" editsize="100" txtcolor="-16777216" txtbkcolor="-7278960" charset="1" />
        <txttip left="252" top="1053" right="339" bottom="1070" content="192.168.1.1" fontname="Consolas" fontstyle="0" editsize="100" txtcolor="-16777216" txtbkcolor="-7278960" charset="1" />
